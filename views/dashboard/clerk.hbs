<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="display-5">Clerk Dashboard</h1>
            <p class="lead mb-0">Please contact an administrator if you need service information.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/" class="btn btn-outline-primary">
                <i class="fas fa-home me-2"></i>Home
            </a>
            <a href="/logout" class="btn btn-danger">
                <i class="fas fa-sign-out-alt me-2"></i>Logout
            </a>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="section-title mb-0">All Services</h3>
</div>

{{!-- Services Table for clerks --}}
{{#if services}}
<div class="table-responsive mb-5">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Title</th>
                <th>Provider</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each services}}
            <tr>
                <td><a href="/services/{{_id}}">{{title}}</a></td>
                <td>{{provider.name}}</td>
                <td>{{category}}</td>
                <td>
                    {{!-- MODIFIED: Displays lock if the clerk has already edited it --}}
                    {{#if this.clerkHasEditedTemplate}}
                        <button class="btn btn-sm btn-outline-danger" disabled><i class="fas fa-lock me-1"></i> Locked</button>
                    {{else}}
                        <a href="/services/edit/{{_id}}" class="btn btn-sm btn-secondary">Edit</a>
                    {{/if}}
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{else}}
<div class="card text-center p-4 mb-5">
    <p class="mb-0">There are no services on the platform.</p>
</div>
{{/if}}
