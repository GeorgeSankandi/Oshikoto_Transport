                            {{#each (array '1' '2' '3')}}
                            <div class="col-md-4 mb-3">
                                <div class="p-3" style="background:#f9fbfd; border-radius:16px;">
                                    <p style="color:#12233a; font-weight:700; margin-bottom:15px;">Team Member {{this}}</p>
                                    <div class="mb-3">
                                        <label class="form-label app-label">Name</label>
                                        <input type="text" name="about_team_{{this}}_name" class="form-control app-input" value="{{lookup ../siteContent (concat 'about_team_' this '_name')}}">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label app-label">Role</label>
                                        <input type="text" name="about_team_{{this}}_title" class="form-control app-input" value="{{lookup ../siteContent (concat 'about_team_' this '_title')}}">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label app-label">Bio</label>
                                        <textarea name="about_team_{{this}}_bio" class="form-control app-input" rows="4">{{lookup ../siteContent (concat 'about_team_' this '_bio')}}</textarea>
                                    </div>
                                    <div>
                                        <label class="form-label app-label">Photo</label>
                                        <input type="file" name="about_team_{{this}}_image" class="form-control app-input img-upload-input" style="padding:10px;" accept="image/*">
                                        
                                        {{#if (lookup ../siteContent (concat 'about_team_' this '_image'))}}
                                        <div class="image-preview-container" style="display: block;">
                                            <img src="{{lookup ../siteContent (concat 'about_team_' this '_image')}}" alt="Preview">
                                        </div>
