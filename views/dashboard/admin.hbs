                        .wt-a4-container { min-width: 800px; max-width: 210mm; padding: 20mm; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); box-sizing: border-box; color: #2c3e50; font-family: Arial, sans-serif; }
