                                {{#if siteContent.about_team_2_image}}<img src="{{siteContent.about_team_2_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.about_team_3_image}}<img src="{{siteContent.about_team_3_image}}" class="header-preview-img">{{/if}}
