                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary w-100">Create Article</button>
                        <button type="button" class="btn btn-secondary w-100" data-bs-toggle="collapse" data-bs-target="#createArticleCollapse">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <h5 class="mt-4">Existing Articles</h5>
    {{#if articles}}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
