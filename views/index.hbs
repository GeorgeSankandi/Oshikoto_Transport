                    <div class="image_container">
                        <img src="{{siteContent.about_team_1_image}}" alt="{{siteContent.about_team_1_name}}" class="team-image">
                    </div>
                    <div class="team-title-modern">
                        <span>{{siteContent.about_team_1_name}}</span>
                    </div>
