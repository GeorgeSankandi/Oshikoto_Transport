                            <button type="button" class="btn btn-secondary w-100 mt-4 btn-lg" data-bs-toggle="collapse" data-bs-target="#createServiceCollapse">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        {{#if services}}
        <div class="fs-rows-wrapper">
            {{#each services}}
            <!-- NEW: Wrapper around the row and history to keep layout clean -->
            <div class="fs-gamer-item mb-3">
                <div class="fs-gamer-row" style="margin-bottom: 0; border-bottom-left-radius: {{#if editHistory}}0{{else}}8px{{/if}}; border-bottom-right-radius: {{#if editHistory}}0{{else}}8px{{/if}};">
                    <div class="fs-row-left">
                        <div class="fs-row-icon">
                            {{#if imageUrl}}
                                <img src="{{imageUrl}}" alt="{{title}}">
                            {{else}}
                                <i class="fas fa-cube"></i>
                            {{/if}}
                        </div>
                        <div class="fs-row-info">
                            <a href="/services/{{_id}}" class="fs-row-title">{{title}}</a>
                            <p class="fs-row-meta">
                                <strong>Provider:</strong> {{provider.name}} 
                                <span style="margin:0 5px; opacity:0.3;">|</span> 
                                <strong>Location:</strong> {{category}}
                                
                                {{#if this.clerkHasEditedTemplate}}
                                <span style="margin:0 5px; opacity:0.3;">|</span> 
                                <strong style="color: #ffb300;"><i class="fas fa-user-edit" style="margin-right:2px;"></i> Last Edited By:</strong> <span style="color:#fff;">{{this.lastEditedByClerkName}}</span> ({{formatDate this.lastEditedByClerkDate 'MMM Do YYYY, HH:mm'}})
                                {{/if}}
                            </p>
                        </div>
                    </div>
                    <div class="fs-row-right">
                        
                        <!-- NEW: History Toggle Button -->
                        <button class="fs-action-btn fs-btn-history" type="button" data-bs-toggle="collapse" data-bs-target="#history-{{_id}}">
                            <i class="fas fa-history"></i> History
                        </button>

                        <a href="/services/edit/{{_id}}" class="fs-action-btn"><i class="fas fa-pen"></i> Edit</a>
                        
                        <form action="/services/{{_id}}?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this service?');">
                            <button type="submit" class="fs-action-btn fs-btn-delete"><i class="fas fa-trash"></i> Delete</button>
                        </form>

                        {{#if this.clerkHasEditedTemplate}}
                        <form action="/services/{{_id}}/unlock-clerk" method="POST" class="d-inline">
                            <button type="submit" class="fs-action-btn fs-btn-unlock" title="Locked by {{this.lastEditedByClerkName}}">
                                <i class="fas fa-lock"></i> Unlock
                            </button>
                        </form>
                        <div class="fs-score-badge" title="Locked on {{formatDate this.lastEditedByClerkDate 'MMM Do YYYY'}}">LOCKED</div>
                        {{else}}
                        <div class="fs-score-badge" style="color: #4fc3f7; border-color: rgba(79, 195, 247, 0.2);">ACTIVE</div>
                        {{/if}}
                    </div>
                </div>

                <!-- NEW: Collapsible History Panel -->
                <div class="collapse w-100" id="history-{{_id}}">
                    <div class="p-3" style="background-color: #0b1118; border: 1px solid rgba(255, 255, 255, 0.04); border-top: none; border-radius: 0 0 8px 8px;">
                        <h6 style="color: #8fa6be; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 10px; letter-spacing: 1px;">Recent Edit History</h6>
                        {{#if this.editHistory}}
                            <ul class="list-unstyled mb-0" style="font-size: 0.85rem; color: #e2e8f0;">
                                {{#each this.editHistory}}
                                    <li class="mb-2 pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <i class="fas fa-edit me-2" style="color: #00b0ff;"></i> 
                                        <strong>{{this.editorName}}</strong> 
                                        <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">{{this.editorRole}}</span>
                                        <span class="text-muted float-end">{{formatDate this.editedAt 'MMM Do YYYY, HH:mm'}}</span>
                                    </li>
                                {{/each}}
                            </ul>
                        {{else}}
                            <p class="mb-0" style="font-size: 0.85rem; color: #5c758e;"><i class="fas fa-info-circle me-1"></i> No edit history recorded yet.</p>
                        {{/if}}
                    </div>
                </div>

            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="fs-gamer-row justify-content-center">
            <p class="fs-row-meta mt-3 mb-3">No services found. Click "Create New" to add one.</p>
        </div>
        {{/if}}
    </div>
  </div>

  <!-- =============================== -->
  <!-- ===    GALLERY PANE         === -->
  <!-- =============================== -->
  {{#if showContentTabs}}
  <div class="tab-pane fade" id="gallery-pane" role="tabpanel" aria-labelledby="gallery-tab" tabindex="0">
    <h3 class="section-title">Image Gallery</h3>
    <p class="text-muted">Manage images uploaded to the website. <strong>Warning:</strong> Deleting an image that is currently in use on the site will result in broken image links.</p>
    
    {{#if uploadedImages}}
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3">
        {{#each uploadedImages}}
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div style="height: 150px; overflow: hidden;" class="bg-light d-flex align-items-center justify-content-center">
                    <img src="{{this.url}}" alt="{{this.name}}" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="card-body p-2 d-flex flex-column">
                    <small class="text-truncate d-block mb-2" title="{{this.name}}" style="font-size: 0.75rem;">{{this.name}}</small>
                    <form action="/dashboard/images/{{this.name}}?_method=DELETE" method="POST" class="mt-auto w-100" onsubmit="return confirm('Are you sure you want to delete this image?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-0" style="font-size: 0.8rem;">
                            <i class="fas fa-trash-alt me-1"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="alert alert-info">No images uploaded yet.</div>
    {{/if}}
  </div>
  {{/if}}

</div>

{{!-- Inline Partial to reduce code repetition for standard switches --}}
{{#*inline "_checklist_switch"}}
    <td class="switch-td">
        <div class="switch-cell">
            <div class="toggle-switch three-state" data-name="{{name}}">
                <div class="switch-control">
                    <input type="radio" name="{{name}}" value="OK" class="status-input status-ok-input">
                    <input type="radio" name="{{name}}" value="N/A" class="status-input status-na-input" checked>
                    <input type="radio" name="{{name}}" value="DEF" class="status-input status-def-input">
                    <span class="slider"></span>
                </div>
            </div>
        </div>
    </td>
    <td class="text-center">
        <input type="time" name="{{name}}_Arr" class="form-control form-control-sm w-100 time-input">
    </td>
{{/inline}}

<script>
    function validatePassword(isSubmit = false) {
        const password = document.getElementById('clerkPassword').value;
        const notification = document.getElementById('passwordNotification');
        const errorList = document.getElementById('passwordErrors');
        
        const errors = [];
        
        if (password.length < 8) {
            errors.push('Must be at least 8 characters long');
        }
        
        if (!/[A-Z]/.test(password)) {
            errors.push('Must contain at least one uppercase letter');
        }
        
        const digitCount = (password.match(/\d/g) || []).length;
        if (digitCount < 2) {
            errors.push('Must contain at least two numbers');
        }
        
        if (errors.length > 0) {
            errorList.innerHTML = errors.map(error => `<li>${error}</li>`).join('');
            notification.style.display = 'block';
            if (isSubmit) {
                // Scroll to notification only on submit
                notification.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
            return false;
        } else {
            notification.style.display = 'none';
            return true;
        }
    }

    function populateEditForm(userId, name, email, role) {
        document.getElementById('editUserId').value = userId;
        document.getElementById('editUserName').value = name;
        document.getElementById('editUserEmail').value = email;
        document.getElementById('editUserRole').value = role;
        document.getElementById('editUserPassword').value = '';
        document.getElementById('editUserPasswordConfirm').value = '';
        document.getElementById('editPasswordNotification').style.display = 'none';
        document.getElementById('confirmPasswordGroup').style.display = 'none';
        
        // Reset password visibility
        document.getElementById('editUserPassword').type = 'password';
        document.getElementById('editUserPasswordConfirm').type = 'password';
        document.getElementById('toggleEditPassword').innerHTML = '<i class="fas fa-eye"></i>';
        document.getElementById('toggleEditPasswordConfirm').innerHTML = '<i class="fas fa-eye"></i>';
    }

    function validateEditPassword(isSubmit = false) {
        const password = document.getElementById('editUserPassword').value;
        const confirmPassword = document.getElementById('editUserPasswordConfirm').value;
        
        // If password is empty, allow update (keeping current password)
        if (!password) {
            document.getElementById('editPasswordNotification').style.display = 'none';
            document.getElementById('confirmPasswordGroup').style.display = 'none';
            return true;
        }
        
        // Show confirmation field when password is entered
        document.getElementById('confirmPasswordGroup').style.display = 'block';
        
        const notification = document.getElementById('editPasswordNotification');
        const errorList = document.getElementById('editPasswordErrors');
        
        const errors = [];
        
        if (password.length < 8) {
            errors.push('Must be at least 8 characters long');
        }
        
        if (!/[A-Z]/.test(password)) {
            errors.push('Must contain at least one uppercase letter');
        }
        
        const digitCount = (password.match(/\d/g) || []).length;
        if (digitCount < 2) {
            errors.push('Must contain at least two numbers');
        }
        
        if (isSubmit && password !== confirmPassword) {
            errors.push('Passwords do not match');
        }
        
        if (errors.length > 0) {
            errorList.innerHTML = errors.map(error => `<li>${error}</li>`).join('');
            notification.style.display = 'block';
            if (isSubmit) {
                notification.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
            return false;
        } else {
            notification.style.display = 'none';
            return true;
        }
    }

    document.addEventListener('DOMContentLoaded', function(){
        
        // Password validation on input for edit form
        const editPasswordInput = document.getElementById('editUserPassword');
        if (editPasswordInput) {
            editPasswordInput.addEventListener('input', function() {
                validateEditPassword();
            });
        }

        const editPasswordConfirmInput = document.getElementById('editUserPasswordConfirm');
        if (editPasswordConfirmInput) {
            editPasswordConfirmInput.addEventListener('input', function() {
                validateEditPassword();
            });
        }

        // Password visibility toggles
        const toggleEditPasswordBtn = document.getElementById('toggleEditPassword');
        if (toggleEditPasswordBtn) {
            toggleEditPasswordBtn.addEventListener('click', function() {
                const passwordField = document.getElementById('editUserPassword');
                const isPassword = passwordField.type === 'password';
                passwordField.type = isPassword ? 'text' : 'password';
                this.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
            });
        }

        const toggleEditPasswordConfirmBtn = document.getElementById('toggleEditPasswordConfirm');
        if (toggleEditPasswordConfirmBtn) {
            toggleEditPasswordConfirmBtn.addEventListener('click', function() {
                const passwordField = document.getElementById('editUserPasswordConfirm');
                const isPassword = passwordField.type === 'password';
                passwordField.type = isPassword ? 'text' : 'password';
                this.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye-slash"></i>';
            });
        }

        // Clear edit form when modal is closed
        const editUserModal = document.getElementById('editUserModal');
        if (editUserModal) {
            editUserModal.addEventListener('hidden.bs.modal', function() {
                document.getElementById('editUserForm').reset();
                document.getElementById('editPasswordNotification').style.display = 'none';
                document.getElementById('confirmPasswordGroup').style.display = 'none';
                // Reset password visibility
                document.getElementById('editUserPassword').type = 'password';
                document.getElementById('editUserPasswordConfirm').type = 'password';
                document.getElementById('toggleEditPassword').innerHTML = '<i class="fas fa-eye"></i>';
                document.getElementById('toggleEditPasswordConfirm').innerHTML = '<i class="fas fa-eye"></i>';
            });
        }
        
        // Password validation on input
        const passwordInput = document.getElementById('clerkPassword');
        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                validatePassword();
            });
        }
        
        // DOM Memory Persistence for Collapsible Sections in "All Content" tab
        const collapses = document.querySelectorAll('.app-light-card .collapse');
        
        collapses.forEach(collapseEl => {
            const id = collapseEl.id;
            // 1. Read saved state on page load
            const state = localStorage.getItem('adminCollapseState_' + id);
            const toggleHeader = document.querySelector(`[data-bs-target="#${id}"]`);
            
            if (state === 'hidden') {
                collapseEl.classList.remove('show');
                if (toggleHeader) {
                    toggleHeader.classList.add('collapsed');
                    toggleHeader.setAttribute('aria-expanded', 'false');
                }
            } else if (state === 'shown') {
                collapseEl.classList.add('show');
                if (toggleHeader) {
                    toggleHeader.classList.remove('collapsed');
                    toggleHeader.setAttribute('aria-expanded', 'true');
                }
            }
            
            // 2. Listen for Bootstrap collapse events to update memory
            collapseEl.addEventListener('hidden.bs.collapse', function () {
                localStorage.setItem('adminCollapseState_' + id, 'hidden');
            });
            collapseEl.addEventListener('shown.bs.collapse', function () {
                localStorage.setItem('adminCollapseState_' + id, 'shown');
            });
        });


        // Client-side Image Preview Logic
        const imgInputs = document.querySelectorAll('.img-upload-input');
        imgInputs.forEach(input => {
            input.addEventListener('change', function() {
                const file = this.files[0];
                const previewContainer = this.nextElementSibling; 
                if(previewContainer && previewContainer.classList.contains('image-preview-container')) {
                    const previewImg = previewContainer.querySelector('img');
                    if (file && file.type.startsWith('image/')) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            previewImg.src = e.target.result;
                            previewContainer.style.display = 'block';
                            
                            // Find corresponding header preview image and update it instantly
                            const cardHeader = input.closest('.app-light-card').querySelector('.app-light-card-header');
                            if(cardHeader) {
                                const previewsContainer = cardHeader.querySelector('.header-previews');
                                if(previewsContainer) {
                                    if(previewsContainer.children.length === 0) {
                                        previewsContainer.innerHTML = `<img src="${e.target.result}" class="header-preview-img">`;
                                    } else {
                                        previewsContainer.children[0].src = e.target.result;
                                    }
                                }
                            }
                        }
                        reader.readAsDataURL(file);
                    } else {
                        previewImg.src = '';
                        previewContainer.style.display = 'none';
                    }
                }
            });
        });

        // Existing Form Handlers
        const form = document.getElementById('createServiceForm');
        if (form) {
            document.addEventListener('click', function(e){
                if (e.target.classList.contains('add-checklist-item')) {
                    e.preventDefault();
                    const docNum = e.target.dataset.doc;
                    const container = document.querySelector(`.checklist-items[data-doc="${docNum}"]`);
                    if (!container) return;
                    
                    const items = container.querySelectorAll('.checklist-item').length;
                    const newIndex = items + 1;
                    const newItem = document.createElement('div');
                    newItem.className = 'checklist-item mb-2';
                    newItem.innerHTML = `
                        <div class="input-group input-group-sm">
                            <input type="text" name="fleet_doc_${docNum}_checklist_${newIndex}_item" class="form-control" placeholder="Item" data-item-index="${newIndex}">
                            <input type="text" name="fleet_doc_${docNum}_checklist_${newIndex}_category" class="form-control" placeholder="Cat" style="max-width: 100px;">
                        </div>
                    `;
                    container.appendChild(newItem);
                }
            });

            const timeInputs = document.querySelectorAll('.time-input');
            function updateTimeInputVisual(input) {
                if (input.value) input.classList.add('filled');
                else input.classList.remove('filled');
            }
            timeInputs.forEach(input => {
                updateTimeInputVisual(input);
                input.addEventListener('input', () => updateTimeInputVisual(input));
            });

            const checklistToggles = document.querySelectorAll('#checklistTemplateSection .toggle-switch.three-state');
            checklistToggles.forEach(switchContainer => {
                const name = switchContainer.dataset.name;
                const isYN = switchContainer.classList.contains('y-n-switch');
                const STATES = isYN ? ['Y', 'N/A', 'N'] : ['OK', 'N/A', 'DEF'];
                
                const inputs = {};
                STATES.forEach(state => {
                    const input = switchContainer.querySelector(`input[value="${state}"]`);
                    if (input) inputs[state] = input;
                });

                switchContainer.addEventListener('click', (e) => {
                    e.preventDefault();
                    let currentValue = null;
                    for (const state of STATES) {
                        if (inputs[state] && inputs[state].checked) {
                            currentValue = state;
                            break;
                        }
                    }
                    const currentIndex = currentValue ? STATES.indexOf(currentValue) : -1;
                    const nextIndex = (currentIndex + 1) % STATES.length;
                    const nextState = STATES[nextIndex];
                    if (inputs[nextState]) {
                        inputs[nextState].checked = true;
                    }
                });
            });

            form.addEventListener('submit', function(e){
                // Serialize Checklist
                const checklistAdmin = document.getElementById('checklistTemplateSection');
                if(checklistAdmin){
                    const data = {};
                    const rows = checklistAdmin.querySelectorAll('table tbody tr');
                    rows.forEach(row => {
                        const checkedRadio = row.querySelector('input[type="radio"]:checked');
                        if (!checkedRadio) return; 
                        const name = checkedRadio.name;
                        const status = checkedRadio.value;
                        const timeInput = row.querySelector('input[type="time"]');
                        const timeVal = timeInput ? timeInput.value : '';
                        data[name] = { Status: status, Arr: timeVal };
                    });

                    const shiftRadio = checklistAdmin.querySelector('input[name="shift"]:checked');
                    if(shiftRadio) data['shift'] = shiftRadio.value;

                    const otherChecks = ['Fire_Extinguisher', 'First_Aid_Kit'];
                    otherChecks.forEach(name => {
                        const radio = checklistAdmin.querySelector(`input[name="${name}"]:checked`);
                        if(radio) data[name] = radio.value;
                    });

                    const infoFields = ['date', 'department', 'registrationNo', 'odometerReading', 'route', 'seatsOccupied', 'toSite', 'return'];
                    infoFields.forEach(field => {
                        const input = checklistAdmin.querySelector(`input[name="${field}"]`);
                        if(input && input.value) data[field] = input.value;
                    });

                    const footerFields = ['remarks', 'remarks_time', 'remarks_signature', 'driverName', 'driverSignature', 'supervisorName', 'supervisorSignature'];
                    footerFields.forEach(field => {
                        const input = checklistAdmin.querySelector(`[name="${field}"]`); 
                        if(input && input.value) data[field] = input.value;
                    });

                    document.getElementById('checklist_template_json').value = JSON.stringify(data);
                }

                // Serialize Work Ticket
                const workTicketAdmin = document.getElementById('workTicketSection');
                if(workTicketAdmin) {
                    const wtData = {};
                    const wtInputs = workTicketAdmin.querySelectorAll('input[name^="wt_"], select[name^="wt_"], textarea[name^="wt_"]');
                    wtInputs.forEach(input => {
                        wtData[input.name] = input.value;
                    });
                    document.getElementById('work_ticket_template_json').value = JSON.stringify(wtData);
                }
            });
        }

        const geoBtn = document.getElementById('btn-geo-locate');
        const geoInput = document.getElementById('contact_map_query');
        if (geoBtn && geoInput) {
            geoBtn.addEventListener('click', function() {
                if (navigator.geolocation) {
                    geoBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Locating...';
                    navigator.geolocation.getCurrentPosition(function(position) {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
                        geoInput.value = `${lat}, ${lng}`;
                        geoBtn.innerHTML = '<i class="fas fa-check"></i> Found';
                        setTimeout(() => geoBtn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Use Current Location', 2000);
                    }, function(error) {
                        alert('Error getting location: ' + error.message);
                        geoBtn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Use Current Location';
                    });
                } else {
                    alert('Geolocation is not supported by this browser.');
                }
            });
        }
    });

    // Persist Show Content Tabs toggle state in localStorage
    const toggleContentTabs = document.getElementById('toggleContentTabs');
    if (toggleContentTabs) {
        // On page load, set from localStorage if available
        const savedState = localStorage.getItem('showContentTabs');
        if (savedState !== null) {
            toggleContentTabs.checked = savedState === 'true';
        }
        // On change, save to localStorage
        toggleContentTabs.addEventListener('change', function() {
            localStorage.setItem('showContentTabs', this.checked);
        });
    }
</script>