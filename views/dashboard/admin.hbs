                                    </div>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                </div>

                <button type="submit" class="app-btn-submit">
                    <i class="far fa-arrow-alt-circle-right"></i> Save All Site Content
                </button>
            </form>
        </div>
    </div>
  </div>
