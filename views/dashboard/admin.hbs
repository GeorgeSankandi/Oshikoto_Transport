  <div class="tab-pane fade" id="services-pane" role="tabpanel" aria-labelledby="services-tab" tabindex="0">
    
    <!-- Gamer Style Scoped CSS specific to this tab row -->
    <style>
        .fs-gamer-container {
            background: linear-gradient(180deg, #101823 0%, #0a1017 100%);
            border-radius: 12px;
            padding: 30px;
            color: #fff;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05), 0 15px 35px rgba(0,0,0,0.4);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin-bottom: 2rem;
        }
        .fs-gamer-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }
        .fs-gamer-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffffff;
            margin: 0;
            letter-spacing: 0.5px;
        }
        .fs-gamer-btn {
            background: #ff5722;
            color: #fff;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 30px;
            padding: 10px 24px;
            border: none;
            box-shadow: 0 4px 15px rgba(255, 87, 34, 0.4);
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .fs-gamer-btn:hover {
            background: #e64a19;
            transform: translateY(-2px);
            color: #fff;
        }
        
        .fs-gamer-row {
            background-color: #121d28;
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            transition: all 0.2s;
        }
        .fs-gamer-row:hover {
            background-color: #182635;
            border-color: rgba(255, 255, 255, 0.08);
        }
        
        .fs-gamer-row::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 20px;
            border-radius: 0 4px 4px 0;
        }
        .fs-gamer-row:nth-child(1n)::before { background-color: #00e676; }
        .fs-gamer-row:nth-child(2n)::before { background-color: #ff5722; }
        .fs-gamer-row:nth-child(3n)::before { background-color: #e91e63; }
        .fs-gamer-row:nth-child(4n)::before { background-color: #00b0ff; }

        .fs-row-left {
            display: flex;
            align-items: center;
            gap: 15px;
            padding-left: 8px;
        }
        .fs-row-icon {
            width: 40px;
            height: 40px;
            background: #0b1118;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #5c758e;
            font-size: 1.1rem;
            border: 1px solid rgba(255,255,255,0.03);
            overflow: hidden;
        }
        .fs-row-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .fs-row-info {
            display: flex;
            flex-direction: column;
        }
        .fs-row-title {
            color: #ffffff !important;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: 2px;
            transition: color 0.2s;
        }
        .fs-row-title:hover {
            color: #fff !important;
            text-decoration: none;
        }
        .fs-row-meta {
            color: #ffffff !important;
            font-size: 0.75rem;
            margin: 0;
            opacity: 0.9;
        }
        .fs-row-meta strong {
            color: #ffffff !important;
            font-weight: 500;
        }

        .fs-row-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .fs-action-btn {
            background: #0b1118;
            color: #8fa6be;
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 6px;
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .fs-action-btn:hover {
            background: #182635;
            color: #fff;
            border-color: rgba(255,255,255,0.1);
        }
        .fs-btn-delete:hover {
            color: #ff5722;
            border-color: rgba(255, 87, 34, 0.3);
        }
        .fs-btn-unlock {
            color: #ffb300;
        }
        .fs-btn-history {
            color: #00b0ff;
        }
        
        .fs-score-badge {
            background: #0b1118;
            color: #00e676;
            font-weight: 700;
            font-size: 0.85rem;
            padding: 4px 10px;
            border-radius: 6px;
            border: 1px solid rgba(0, 230, 118, 0.2);
            margin-left: 10px;
        }
        
        /* Mobile Tweaks */
        @media (max-width: 768px) {
            .fs-gamer-container { padding: 15px; border-radius: 20px; }
            .fs-gamer-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .fs-gamer-row { flex-direction: column; align-items: flex-start; gap: 15px; padding: 15px; }
            .fs-row-right { flex-wrap: wrap; width: 100%; gap: 10px; }
            .fs-score-badge { margin-left: 0; }
        }
    </style>

    <div class="fs-gamer-container">
        <div class="fs-gamer-header">
            <h3 class="fs-gamer-title">All Services on Platform</h3>
