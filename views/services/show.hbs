<!-- MODIFIED: Dedicated script for direct HTML to PDF conversion -->
<script>
    function downloadSectionPDF(elementId, filename, btn) {
        const element = document.getElementById(elementId);
        if(!element) return;
        
        // Save original button state and show loading
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Generating PDF...';
        btn.disabled = true;

        // html2pdf options
        const opt = {
            margin:       [0.3, 0.1], // Minimal Top/Bottom, Left/Right margins
            filename:     filename,
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { 
                scale: 2, 
                useCORS: true,
                windowWidth: 1200, // Forces desktop layout to prevent flexbox stacking
                backgroundColor: '#ffffff' // Ensures white background
            },
            jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' },
            pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] } // Prevents page breaks
        };

        // html2pdf is globally available via the CDN included in main.hbs
        html2pdf().set(opt).from(element).save().then(() => {
            // Restore button state on success
            btn.innerHTML = originalText;
            btn.disabled = false;
        }).catch(err => {
            console.error('PDF generation error:', err);
            btn.innerHTML = originalText;
            btn.disabled = false;
            alert('Error generating PDF. Please check the console.');
        });
    }
</script>
{{/if}}



