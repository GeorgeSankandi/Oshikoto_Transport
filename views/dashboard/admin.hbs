        <div class="collapse mb-4" id="createServiceCollapse">
            <div class="card shadow-sm border-0" style="background:#121d28; color:#e2e8f0;">
                <div class="card-body p-4">
                    <h5 class="card-title mb-4" style="color:#fff;">Create New Service</h5>
                    
                    {{!-- Checklist Styling --}}
                    <div class="checklist-page">
