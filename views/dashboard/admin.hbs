  <!-- =============================== -->
  <!-- ===    USERS PANE           === -->
  <!-- =============================== -->
  <div class="tab-pane fade {{#if showContentTabs}}{{else}}show active{{/if}}" id="users-pane" role="tabpanel" aria-labelledby="users-tab" tabindex="0">
    
    <!-- SECURITY WARNING BANNER -->
    <div class="alert alert-warning mb-4" role="alert">
        <h5 class="alert-heading">
            <i class="fas fa-exclamation-circle me-2"></i>Security Notice
        </h5>
        <p class="mb-0">This page displays user passwords in <strong>hashed form</strong>. Passwords are securely stored and cannot be reversed. Only users with admin access should view this page.</p>
    </div>
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h3 class="section-title mb-0">Manage Users</h3>
        <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#createUserCollapse" aria-expanded="false" aria-controls="createUserCollapse">
            <i class="fas fa-user-plus me-2"></i>Create New Clerk
        </button>
    </div>

    <div class="collapse mb-4" id="createUserCollapse">
        <div class="card border-primary shadow-sm">
            <div class="card-body p-4">
                <h5 class="card-title text-primary mb-3">Create Clerk Account</h5>
                
                <!-- Password Validation Notification -->
                <div id="passwordNotification" class="alert alert-danger" style="display: none;" role="alert">
                    <strong>Password Requirements Not Met:</strong>
                    <ul id="passwordErrors" class="mb-0"></ul>
                </div>
                
                <form action="/dashboard/users/clerk" method="POST" id="createClerkForm" onsubmit="return validatePassword(true)">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Password</label>
                            <input type="password" name="password" id="clerkPassword" class="form-control" required>
                        </div>
                        <div class="col-md-3 d-flex gap-2">
                            <button type="submit" class="btn btn-primary w-100">Create</button>
                            <button type="button" class="btn btn-secondary w-100" data-bs-toggle="collapse" data-bs-target="#createUserCollapse">Cancel</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editUserModalLabel">Edit User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Password Validation Notification for Edit -->
                    <div id="editPasswordNotification" class="alert alert-danger" style="display: none;" role="alert">
                        <strong>Password Requirements Not Met:</strong>
                        <ul id="editPasswordErrors" class="mb-0"></ul>
                    </div>
                    
                    <form action="/dashboard/users/update" method="POST" id="editUserForm" onsubmit="return validateEditPassword(true)">
                        <input type="hidden" name="_method" value="PUT">
                        <input type="hidden" name="userId" id="editUserId">
                        
                        <div class="mb-3">
                            <label for="editUserName" class="form-label">Full Name</label>
                            <input type="text" name="name" class="form-control" id="editUserName" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="editUserEmail" class="form-label">Email Address</label>
                            <input type="email" name="email" class="form-control" id="editUserEmail" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="editUserRole" class="form-label">Role</label>
                            <select name="role" class="form-control" id="editUserRole" required>
                                <option value="client">Client</option>
                                <option value="provider">Provider</option>
                                <option value="clerk">Clerk</option>
                                <option value="admin" disabled>Admin (Cannot change via edit)</option>
                            </select>
                            <div class="form-text">Note: Admin role cannot be assigned or changed through this interface.</div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="editUserPassword" class="form-label">New Password (leave blank to keep current)</label>
                            <div class="input-group">
                                <input type="password" name="password" class="form-control" id="editUserPassword">
                                <button class="btn btn-outline-secondary" type="button" id="toggleEditPassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <div class="form-text">
                                <small class="text-muted">Current password is securely hashed and cannot be viewed. Only enter a new password if you want to change it.</small>
                            </div>
                        </div>
                        
                        <div class="mb-3" id="confirmPasswordGroup" style="display: none;">
                            <label for="editUserPasswordConfirm" class="form-label">Confirm New Password</label>
                            <div class="input-group">
                                <input type="password" name="passwordConfirm" class="form-control" id="editUserPasswordConfirm">
                                <button class="btn btn-outline-secondary" type="button" id="toggleEditPasswordConfirm">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Update User</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mt-4">All Registered Users</h5>
    {{#if allUsers}}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Password</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {{#each allUsers}}
                <tr>
                    <td>{{this.name}}</td>
                    <td>{{this.email}}</td>
                    <td><span class="badge bg-secondary">{{this.role}}</span></td>
                    <td>{{formatDate this.createdAt 'YYYY-MM-DD'}}</td>
                    <td>
                        <code class="bg-light p-2 rounded text-muted small" title="Hashed password" style="word-break: break-all;">
                            {{this.password}}
                        </code>
                    </td>
                    <td>
                        {{#unless (ifeq this.role 'admin')}}
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#editUserModal" onclick="populateEditForm('{{this._id}}', '{{this.name}}', '{{this.email}}', '{{this.role}}')">
                                Edit
                            </button>
                            <form action="/dashboard/users/{{this._id}}?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                <input type="submit" value="Delete" class="btn btn-sm btn-danger">
                            </form>
                        </div>
                        {{else}}
                        <span class="text-muted small">Admin</span>
                        {{/unless}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{else}}
    <p>No users found.</p>
    {{/if}}
  </div>

  <!-- =============================== -->
  <!-- ===    ARTICLES PANE        === -->
  <!-- =============================== -->
  {{#if showContentTabs}}
  <div class="tab-pane fade" id="articles-pane" role="tabpanel" aria-labelledby="articles-tab" tabindex="0">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h3 class="section-title mb-0">Manage Articles</h3>
        <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#createArticleCollapse" aria-expanded="false" aria-controls="createArticleCollapse">
            <i class="fas fa-plus me-2"></i>Create New Article
        </button>
