<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-3">
    <div>
        <h1 class="display-5 mb-0">Admin Dashboard</h1>
        <p class="lead text-muted mb-0">Welcome, {{user.name}}. Full control panel.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/" class="btn btn-outline-primary w-100">
            <i class="fas fa-home me-2"></i>Home
        </a>
        <a href="/logout" class="btn btn-danger w-100">
            <i class="fas fa-sign-out-alt me-2"></i>Logout
        </a>
    </div>
</div>
<hr>

<div class="mb-3">
    <form action="/dashboard/toggle-content-tabs" method="POST" class="d-inline">
        <label class="form-check-label me-2" for="toggleContentTabs">Show Content Tabs</label>
        <div class="form-check form-switch d-inline" style="margin-left: 10%;">
            <input class="form-check-input" type="checkbox" id="toggleContentTabs" name="dummy" onchange="this.form.submit()" {{#if showContentTabs}}checked{{/if}} style="margin-left: 10%;">
        </div>
    </form>
</div>

<!-- Tab Navigation (Mobile Scrollable) -->
<ul class="nav nav-tabs mb-4 flex-nowrap overflow-auto" id="adminTab" role="tablist" style="white-space: nowrap; padding-bottom: 5px;">
  {{#if showContentTabs}}
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="content-tab" data-bs-toggle="tab" data-bs-target="#content-pane" type="button" role="tab" aria-controls="content-pane" aria-selected="true">All Content</button>
  </li>
  {{/if}}
  <li class="nav-item" role="presentation">
    <button class="nav-link {{#if showContentTabs}}{{else}}active{{/if}}" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-pane" type="button" role="tab" aria-controls="users-pane" aria-selected="{{#if showContentTabs}}false{{else}}true{{/if}}">Users</button>
  </li>
  {{#if showContentTabs}}
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="articles-tab" data-bs-toggle="tab" data-bs-target="#articles-pane" type="button" role="tab" aria-controls="articles-pane" aria-selected="false">Articles</button>
  </li>
  {{/if}}
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="services-tab" data-bs-toggle="tab" data-bs-target="#services-pane" type="button" role="tab" aria-controls="services-pane" aria-selected="false">Site Content</button>
  </li>
  {{#if showContentTabs}}
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="gallery-tab" data-bs-toggle="tab" data-bs-target="#gallery-pane" type="button" role="tab" aria-controls="gallery-pane" aria-selected="false">Image Gallery</button>
  </li>
  {{/if}}
</ul>

<!-- Tab Content -->
<div class="tab-content" id="adminTabContent">

  <!-- ================================== -->
  <!-- === ALL CONTENT MANAGER PANE   === -->
  <!-- ================================== -->
  {{#if showContentTabs}}
  <div class="tab-pane fade show active" id="content-pane" role="tabpanel" aria-labelledby="content-tab" tabindex="0">
    
    <!-- Custom Scoped Styling matching the UI reference image -->
    <style>
        .app-dark-wrapper {
            background-color: #12233a; /* Deep navy background */
            border-radius: 40px;
            padding: 30px;
            color: #ffffff;
            box-shadow: 0 20px 40px rgba(18, 35, 58, 0.15);
            font-family: 'Poppins', sans-serif;
            margin-bottom: 2rem;
        }
        .app-dark-header {
            margin-bottom: 30px;
            padding: 0 10px;
        }
        .app-dark-header h3 {
            color: #ffffff;
            font-weight: 600;
            font-size: 1.6rem;
            margin-bottom: 5px;
            letter-spacing: 0.5px;
        }
        .app-dark-header p {
            color: #8da4c0;
            font-size: 0.95rem;
            margin-bottom: 0;
        }
        .app-light-container {
            background-color: #ebf0f5; /* Light frosty blue bottom section */
            border-radius: 35px;
            padding: 30px;
            color: #12233a;
        }
        .app-light-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.03);
            border: none;
        }
        
        /* Collapsible Header Styling */
        .app-light-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            user-select: none;
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .app-light-card-title {
            color: #12233a;
            font-weight: 700;
            margin-bottom: 0 !important;
            font-size: 1.15rem;
        }
        .app-light-card-header .toggle-icon {
            transition: transform 0.3s ease;
            color: #62778c;
            font-size: 1.2rem;
        }
        .app-light-card-header:not(.collapsed) .toggle-icon {
            transform: rotate(180deg);
        }
        
        /* Minimized Image Previews in Header */
        .header-previews {
            display: none; /* Hidden when expanded */
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }
        .app-light-card-header.collapsed .header-previews {
            display: flex; /* Visible when collapsed */
        }
        .header-preview-img {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid #c5d2e0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .app-light-card hr {
            border-color: #d1dde8;
            margin: 24px 0;
            opacity: 1;
        }
        .app-input {
            background-color: #f4f7fa;
            border: 1px solid transparent;
            border-radius: 16px;
            padding: 14px 18px;
            color: #12233a;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.2s;
            width: 100%;
        }
        .app-input:focus {
            background-color: #ffffff;
            border-color: #c5d2e0;
            box-shadow: 0 0 0 4px rgba(197, 210, 224, 0.3);
            outline: none;
        }
        .app-label {
            color: #62778c;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }
        .app-btn-submit {
            background: linear-gradient(135deg, #e3cdff 0%, #c19bf5 100%);
            color: #2b1154;
            border-radius: 24px;
            padding: 18px;
            font-weight: 700;
            font-size: 1.1rem;
            border: none;
            width: 100%;
            margin-top: 10px;
            transition: transform 0.2s, opacity 0.3s;
            box-shadow: 0 8px 25px rgba(193, 155, 245, 0.4);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }
        .app-btn-submit:hover {
            transform: translateY(-3px);
            opacity: 0.95;
            color: #2b1154;
        }
        .app-btn-yellow {
            background: #fbd68b;
            color: #7a5100;
            border-radius: 14px;
            border: none;
            font-weight: 600;
            padding: 12px 24px;
            transition: opacity 0.2s;
            white-space: nowrap;
        }
        .app-btn-yellow:hover {
            opacity: 0.85;
            color: #7a5100;
        }
        .app-switch .form-check-input {
            width: 3.5em;
            height: 1.75em;
            cursor: pointer;
            flex-shrink: 0;
        }
        .app-switch .form-check-input:checked {
            background-color: #12233a;
            border-color: #12233a;
        }
        .app-sub-section {
            border-bottom: 1px dashed #d1dde8;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
        .app-sub-section:last-child {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }
        
        .image-preview-container {
            margin-top: 12px;
            display: none;
            border-radius: 12px;
            overflow: hidden;
            border: 2px dashed #c5d2e0;
            max-width: 250px;
            height: 140px;
            background-color: #f4f7fa;
            position: relative;
        }
        .image-preview-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* MOBILE RESPONSIVE TWEAKS */
        @media (max-width: 768px) {
            .app-dark-wrapper { padding: 15px; border-radius: 20px; }
            .app-light-container { padding: 15px; border-radius: 20px; }
            .app-light-card { padding: 15px; border-radius: 15px; }
            .app-light-card-header { align-items: flex-start; }
            .app-light-card-header .toggle-icon { margin-top: 3px; }
            .header-left { flex-direction: column; align-items: flex-start; gap: 10px; }
            .app-light-card-title { font-size: 1.05rem; }
            .app-btn-yellow { padding: 12px 15px; font-size: 0.85rem; }
        }
    </style>

    <div class="app-dark-wrapper">
        <div class="app-dark-header">
            <h3>Manage Site Content</h3>
            <p>Update page content, configurations, and global assets.</p>
        </div>
        
        <div class="app-light-container">
            <form action="/dashboard/site-content" method="POST" enctype="multipart/form-data">
                
                <div class="app-light-card">
                    <!-- Collapse Toggle Header -->
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-general" aria-expanded="true" aria-controls="collapse-general">
                        <div class="header-left">
                            <div class="app-light-card-title">General Page Configurations</div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    
                    <!-- Collapsible Content -->
                    <div id="collapse-general" class="collapse show mt-4">
                        <!-- Feature: Portfolio Toggle & Text -->
                        <div class="mb-4 app-switch">
                            <label class="form-label app-label">Construction Page: Portfolio Section</label>
                            <div class="form-check form-switch mb-3 d-flex align-items-center gap-3">
                                <input class="form-check-input mt-0" type="checkbox" id="construction_portfolio_visible" name="construction_portfolio_visible" value="true" {{#if (ifeq siteContent.construction_portfolio_visible 'true')}}checked{{/if}}>
                                <label class="form-check-label mb-0" for="construction_portfolio_visible" style="font-weight:600; color:#12233a;">Show "Featured Projects"</label>
                            </div>
                            <label class="form-label app-label">Portfolio Intro Text</label>
                            <textarea name="construction_portfolio_intro" class="form-control app-input" rows="2">{{siteContent.construction_portfolio_intro}}</textarea>
                        </div>

                        <hr>

                        <!-- Feature: About Team Text -->
                        <div class="mb-4">
                            <label class="form-label app-label">About Page: "Meet Our Team" Intro</label>
                            <textarea name="about_team_intro" class="form-control app-input" rows="2">{{siteContent.about_team_intro}}</textarea>
                        </div>

                        <hr>

                        <!-- Feature: Contact Map -->
                        <div>
                            <label class="form-label app-label">Contact Page: Map Location</label>
                            <div class="input-group">
                                <input type="text" id="contact_map_query" name="contact_map_query" class="form-control app-input" value="{{siteContent.contact_map_query}}" placeholder="e.g. Windhoek, Namibia">
                                <button class="app-btn-yellow" type="button" id="btn-geo-locate">
                                    <i class="fas fa-map-marker-alt"></i> Locate
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-heroes" aria-expanded="true" aria-controls="collapse-heroes">
                        <div class="header-left">
                            <div class="app-light-card-title">1. Hero Sections Content</div>
                            <div class="header-previews">
                                {{#if siteContent.home_hero_image}}<img src="{{siteContent.home_hero_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.about_hero_image}}<img src="{{siteContent.about_hero_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.services_hero_image}}<img src="{{siteContent.services_hero_image}}" class="header-preview-img">{{/if}}
                            </div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    
                    <div id="collapse-heroes" class="collapse show mt-4">
                        {{#each (array 'home' 'about' 'services' 'articles' 'contact')}}
                        <div class="app-sub-section">
                            <h6 class="text-capitalize" style="color:#12233a; font-weight: 600; margin-bottom:15px;">{{this}} Page Hero</h6>
                            <div class="mb-3">
                                <label class="form-label app-label">Hero Title</label>
                                <input type="text" name="{{this}}_hero_title" class="form-control app-input" value="{{lookup ../siteContent (concat this '_hero_title')}}">
                            </div>
                            <div class="mb-3">
                                <label class="form-label app-label">Hero Subtitle</label>
                                <input type="text" name="{{this}}_hero_subtitle" class="form-control app-input" value="{{lookup ../siteContent (concat this '_hero_subtitle')}}">
                            </div>
                            <div>
                                <label class="form-label app-label">Hero Background Image</label>
                                <input type="file" name="{{this}}_hero_image" class="form-control app-input img-upload-input" accept="image/*">
                                
                                <!-- PREVIEW -->
                                {{#if (lookup ../siteContent (concat this '_hero_image'))}}
                                <div class="image-preview-container" style="display: block;">
                                    <img src="{{lookup ../siteContent (concat this '_hero_image')}}" alt="Preview">
                                </div>
                                {{else}}
                                <div class="image-preview-container">
                                    <img src="" alt="Preview">
                                </div>
                                {{/if}}

                                <small style="color:#8da4c0; display:block; margin-top:6px; font-weight:500;">Current file: {{lookup ../siteContent (concat this '_hero_image')}}</small>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>

                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-home-about" aria-expanded="true" aria-controls="collapse-home-about">
                        <div class="header-left">
                            <div class="app-light-card-title">2. Home Page "About" Section</div>
                            <div class="header-previews">
                                {{#if siteContent.home_about_image}}<img src="{{siteContent.home_about_image}}" class="header-preview-img">{{/if}}
                            </div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    
                    <div id="collapse-home-about" class="collapse show mt-4">
                        <div class="mb-3">
                            <label for="home_about_text" class="form-label app-label">About Section Text</label>
                            <textarea id="home_about_text" name="home_about_text" class="form-control app-input" rows="4">{{siteContent.home_about_text}}</textarea>
                        </div>
                        <div>
                            <label for="home_about_image" class="form-label app-label">About Section Image</label>
                            <input type="file" id="home_about_image" name="home_about_image" class="form-control app-input img-upload-input" accept="image/*">
                            
                            {{#if siteContent.home_about_image}}
                            <div class="image-preview-container" style="display: block;">
                                <img src="{{siteContent.home_about_image}}" alt="Preview">
                            </div>
                            {{else}}
                            <div class="image-preview-container">
                                <img src="" alt="Preview">
                                </div>
                            {{/if}}

                            <small style="color:#8da4c0; display:block; margin-top:6px; font-weight:500;">Current file: {{siteContent.home_about_image}}</small>
                        </div>
                    </div>
                </div>

                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-pillars" aria-expanded="true" aria-controls="collapse-pillars">
                        <div class="header-left">
                            <div class="app-light-card-title">3. Individual Service Pillar Pages</div>
                            <div class="header-previews">
                                {{#if siteContent.transport_section_image}}<img src="{{siteContent.transport_section_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.construction_section_image}}<img src="{{siteContent.construction_section_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.technical_section_image}}<img src="{{siteContent.technical_section_image}}" class="header-preview-img">{{/if}}
                            </div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    
                    <div id="collapse-pillars" class="collapse show mt-4">
                        {{#each (array 'transport' 'construction' 'technical' 'general')}}
                        <div class="app-sub-section">
                            <h6 class="text-capitalize" style="color:#12233a; font-weight: 600; margin-bottom:15px;">{{this}} Page Content</h6>
                            <div class="mb-3">
                                <label class="form-label app-label">Section Title</label>
                                <input type="text" name="{{this}}_section_title" class="form-control app-input" value="{{lookup ../siteContent (concat this '_section_title')}}">
                            </div>
                            <div class="mb-3">
                                <label class="form-label app-label">Section Description</label>
                                <textarea name="{{this}}_section_desc" class="form-control app-input" rows="4">{{lookup ../siteContent (concat this '_section_desc')}}</textarea>
                            </div>
                            <div>
                                <label class="form-label app-label">Section Image</label>
                                <input type="file" name="{{this}}_section_image" class="form-control app-input img-upload-input" accept="image/*">
                                
                                {{#if (lookup ../siteContent (concat this '_section_image'))}}
                                <div class="image-preview-container" style="display: block;">
                                    <img src="{{lookup ../siteContent (concat this '_section_image')}}" alt="Preview">
                                </div>
                                {{else}}
                                <div class="image-preview-container">
                                    <img src="" alt="Preview">
                                </div>
                                {{/if}}

                                <small style="color:#8da4c0; display:block; margin-top:6px; font-weight:500;">Current file: {{lookup ../siteContent (concat this '_section_image')}}</small>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
                
                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-about-transport" aria-expanded="true" aria-controls="collapse-about-transport">
                        <div class="header-left">
                            <div class="app-light-card-title">4. About Us Page - Transportation</div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div id="collapse-about-transport" class="collapse show mt-4">
                        <div>
                            <label class="form-label app-label">Transportation Body Text</label>
                            <textarea name="about_transport_text" class="form-control app-input" rows="4">{{siteContent.about_transport_text}}</textarea>
                        </div>
                    </div>
                </div>

                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-mission-vision" aria-expanded="true" aria-controls="collapse-mission-vision">
                        <div class="header-left">
                            <div class="app-light-card-title">5. About Us - Mission, Vision & Why Us</div>
                            <div class="header-previews">
                                {{#if siteContent.about_mission_image}}<img src="{{siteContent.about_mission_image}}" class="header-preview-img">{{/if}}
                                {{#if siteContent.about_vision_image}}<img src="{{siteContent.about_vision_image}}" class="header-preview-img">{{/if}}
                            </div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    
                    <div id="collapse-mission-vision" class="collapse show mt-4">
                        <div class="row">
                            <!-- Mission -->
                            <div class="col-md-6 mb-4">
                                <label class="form-label app-label">Our Mission Text</label>
                                <textarea name="about_mission_text" class="form-control app-input mb-3" rows="3">{{siteContent.about_mission_text}}</textarea>
                                <label class="form-label app-label">Mission Image</label>
                                <input type="file" name="about_mission_image" class="form-control app-input img-upload-input" accept="image/*">
                                
                                {{#if siteContent.about_mission_image}}
                                <div class="image-preview-container" style="display: block;">
                                    <img src="{{siteContent.about_mission_image}}" alt="Preview">
                                </div>
                                {{else}}
                                <div class="image-preview-container">
                                    <img src="" alt="Preview">
                                </div>
                                {{/if}}

                                <small style="color:#8da4c0; display:block; margin-top:6px; font-weight:500;">Current file: {{siteContent.about_mission_image}}</small>
                            </div>
                            
                            <!-- Vision -->
                            <div class="col-md-6 mb-4">
                                <label class="form-label app-label">Our Vision Text</label>
                                <textarea name="about_vision_text" class="form-control app-input mb-3" rows="3">{{siteContent.about_vision_text}}</textarea>
                                <label class="form-label app-label">Vision Image</label>
                                <input type="file" name="about_vision_image" class="form-control app-input img-upload-input" accept="image/*">
                                
                                {{#if siteContent.about_vision_image}}
                                <div class="image-preview-container" style="display: block;">
                                    <img src="{{siteContent.about_vision_image}}" alt="Preview">
                                </div>
                                {{else}}
                                <div class="image-preview-container">
                                    <img src="" alt="Preview">
                                </div>
                                {{/if}}

                                <small style="color:#8da4c0; display:block; margin-top:6px; font-weight:500;">Current file: {{siteContent.about_vision_image}}</small>
                            </div>
                        </div>

                        <hr>
                        <label class="form-label app-label" style="color:#12233a; font-size:1rem;">"Why Choose Us" Section</label>
                        <div class="row mt-3">
                            <div class="col-md-6 mb-3">
                                <input type="text" name="about_why_1_title" class="form-control app-input mb-2" value="{{siteContent.about_why_1_title}}" placeholder="Title 1">
                                <textarea name="about_why_1_text" class="form-control app-input" rows="2" placeholder="Desc 1">{{siteContent.about_why_1_text}}</textarea>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" name="about_why_2_title" class="form-control app-input mb-2" value="{{siteContent.about_why_2_title}}" placeholder="Title 2">
                                <textarea name="about_why_2_text" class="form-control app-input" rows="2" placeholder="Desc 2">{{siteContent.about_why_2_text}}</textarea>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" name="about_why_3_title" class="form-control app-input mb-2" value="{{siteContent.about_why_3_title}}" placeholder="Title 3">
                                <textarea name="about_why_3_text" class="form-control app-input" rows="2" placeholder="Desc 3">{{siteContent.about_why_3_text}}</textarea>
                            </div>
                            <div class="col-md-6 mb-3">
                                <input type="text" name="about_why_4_title" class="form-control app-input mb-2" value="{{siteContent.about_why_4_title}}" placeholder="Title 4">
                                <textarea name="about_why_4_text" class="form-control app-input" rows="2" placeholder="Desc 4">{{siteContent.about_why_4_text}}</textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="app-light-card">
                    <div class="app-light-card-header" data-bs-toggle="collapse" data-bs-target="#collapse-contact" aria-expanded="true" aria-controls="collapse-contact">
                        <div class="header-left">
                            <div class="app-light-card-title">6. Contact Us Page Details</div>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div id="collapse-contact" class="collapse show mt-4">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label app-label">Intro Title</label>
                                <input type="text" name="contact_intro_title" class="form-control app-input" value="{{siteContent.contact_intro_title}}">
                            </div>
                             <div class="col-md-6 mb-3">
                                <label class="form-label app-label">Address</label>
                                <input type="text" name="contact_address" class="form-control app-input" value="{{siteContent.contact_address}}">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label app-label">Email</label>
