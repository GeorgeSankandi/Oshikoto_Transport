</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form');
        
        // Serialize forms before submission
        form.addEventListener('submit', function(e) {
            
            // 1. Checklist Serialization
            const checklistSection = document.getElementById('checklistTemplateSection');
            if (checklistSection) {
                const checklistData = {};
                const radios = checklistSection.querySelectorAll('input[type="radio"]:checked');
                radios.forEach(radio => {
                    checklistData[radio.name] = radio.value;
                });
                if (Object.keys(checklistData).length > 0) {
                    document.getElementById('checklist_template_json').value = JSON.stringify(checklistData);
                }
            }

            // 2. Work Ticket Serialization
            const wtSection = document.getElementById('workTicketSection');
            if (wtSection) {
                const wtData = {};
                const wtInputs = wtSection.querySelectorAll('input[name^="wt_"], select[name^="wt_"], textarea[name^="wt_"]');
                wtInputs.forEach(input => {
                    wtData[input.name] = input.value;
                });
                document.getElementById('work_ticket_template_json').value = JSON.stringify(wtData);
            }
        });
    });
</script>