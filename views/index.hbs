{{!-- MODIFIED: About Section --}}
<section id="about-home" class="py-5">
    <div class="container">
        <div class="row align-items-center gx-5">
            {{!-- Text Column --}}
            <div class="col-lg-6">
                <h2 class="section-title">Your Trusted Partner in Namibia</h2>
                <p class="lead text-muted" style="text-align: justify;">
                    {{siteContent.home_about_text}}
                </p>
                <a href="/about" class="btn btn-primary mt-3">Learn More About Us</a>
            </div>
            {{!-- Image Column --}}
            <div class="col-lg-6 mt-4 mt-lg-0">
                {{#if siteContent.home_about_image}}
                    <img src="{{siteContent.home_about_image}}" class="img-fluid rounded" alt="Oshikoto Transport and Investment CC" style="box-shadow: var(--shadow);">
                {{/if}}
            </div>
        </div>
    </div>
</section>

<!-- ========================== -->
<!-- === CORE SERVICES SECTION === -->
<!-- ========================== -->
<section id="services-home" class="py-5" style="background-color: var(--light-gray);">
    <div class="container">
        <h2 class="text-center section-title">Our Core Services</h2>
        <div class="row text-center g-4 justify-content-center"> {{!-- MODIFIED: Centered remaining item --}}
            <div class="col-lg-4 col-md-6"> {{!-- MODIFIED: Wider column --}}
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-truck mx-auto mb-3 text-primary" viewBox="0 0 16 16"><path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5zm1.294 7.456A1.999 1.999 0 0 1 4.732 11h5.536a2 2 0 0 1 .732-.732V3.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v7a.5.5 0 0 0 .294.456M12 10a2 2 0 0 1 1.732 1h.768a.5.5 0 0 0 .5-.5V8.35a.5.5 0 0 0-.11-.312l-1.48-1.85A.5.5 0 0 0 13.02 6H12zM5 11a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0m9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2m-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0"/></svg>
                        <h5 class="card-title">Transportation</h5>
                        <p class="card-text">Reliable and efficient transportation services for various commercial and industrial needs.</p>
                        <a href="/transportation" class="btn btn-secondary mt-auto">View More</a>
                    </div>
                </div>
            </div>
            
            {{!-- REMOVED: Other service cards were removed --}}
        </div>
    </div>
</section>

<!-- Our Team Section (Modern Card Style) -->
<section class="team-section py-5">
